{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true
  },
  "watchOptions": {
    "ignored": [
      "**/logs/**",
      "**/workspace/**",
      "**/sessions/**",
      "**/dist/**",
      "**/node_modules/**",
      "**/Frontend/**",
      "**/docs/**",
      "**/.worktrees/**",
      "**/claude-code/**"
    ]
  }
}
